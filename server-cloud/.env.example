# BoardGPT cloud backend — copy to .env and fill in.
# Required for the server to boot: MONGODB_URI and JWT_SECRET.
# Razorpay vars are optional: without them the /api/checkout and /api/webhook
# routes return 503 but the rest of the server runs normally.

PORT=4000

# MongoDB Atlas (or any MongoDB) connection string. REQUIRED.
# e.g. mongodb+srv://user:pass@cluster0.xxxxx.mongodb.net/boardgpt?retryWrites=true&w=majority
MONGODB_URI=

# Secret used to sign JWTs. REQUIRED. Use a long random string.
JWT_SECRET=

# --- Razorpay Subscriptions (hosted checkout) ---
# Get the API keys from the Razorpay dashboard: Settings → API Keys → Generate.
# Test keys start rzp_test_..., live keys rzp_live_.... The secret is shown once.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Webhook signing secret. Dashboard → Settings → Webhooks → Add New Webhook,
# point it at https://YOUR_HOST/api/webhook, choose an "active_secret" and paste
# the SAME value here. Subscribe to these events:
#   subscription.activated, subscription.charged, subscription.resumed,
#   subscription.cancelled, subscription.completed, subscription.halted
RAZORPAY_WEBHOOK_SECRET=

# Subscription Plan IDs (plan_...). Create two plans — monthly ₹99 and yearly
# ₹799 (INR) — then paste their IDs here. The easiest way is:
#   npm run create-plans     (uses the keys above and prints both IDs)
# Or create them by hand: Dashboard → Subscriptions → Plans → Create Plan.
RAZORPAY_PLAN_MONTHLY=
RAZORPAY_PLAN_YEARLY=

# Optional: number of billing cycles before a subscription auto-completes.
# Defaults: 120 monthly cycles (~10 years), 10 yearly cycles (10 years).
PREMIUM_TOTAL_COUNT_MONTHLY=120
PREMIUM_TOTAL_COUNT_YEARLY=10

# Where the client returns after checkout (your extension options page or site).
CLIENT_URL=http://localhost:5173
