# BoardGPT cloud backend — copy to .env and fill in.
# Required for the server to boot: MONGODB_URI and JWT_SECRET.
# Stripe keys are optional: without them the /api/checkout and /api/webhook
# routes return 503 but the rest of the server runs normally.

PORT=4000

# MongoDB Atlas (or any MongoDB) connection string. REQUIRED.
# e.g. mongodb+srv://user:pass@cluster0.xxxxx.mongodb.net/boardgpt?retryWrites=true&w=majority
MONGODB_URI=

# Secret used to sign JWTs. REQUIRED. Use a long random string.
JWT_SECRET=

# Stripe secret key (sk_test_... / sk_live_...). Enables the payment routes.
STRIPE_SECRET_KEY=

# Stripe webhook signing secret (whsec_...). Required to verify /api/webhook events.
STRIPE_WEBHOOK_SECRET=

# Stripe recurring Price IDs for the two subscription plans (price_...).
STRIPE_PRICE_MONTHLY=
STRIPE_PRICE_YEARLY=

# Where Stripe Checkout redirects back to (your extension options page or site).
CLIENT_URL=http://localhost:5173
