# Copy to .env and adjust. All optional — the server runs in-memory without any.
PORT=3000
# Postgres connection. Leave unset to use the in-memory store (demo/testing).
DATABASE_URL=postgres://chessai:chessai@localhost:5432/chessai
# Require this key on /api/analyze and /api/explain when set.
API_KEY=
# Enables real Claude explanations on /api/explain.
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-5
DEMO_USER_ID=demo
